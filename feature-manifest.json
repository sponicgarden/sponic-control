{
  "_meta": {
    "description": "Maps features to their files, directories, edge functions, and DB tables. Used by the setup wizard to select features, prune content, and generate documentation based on the selected persona and individual feature choices.",
    "categories": {
      "communication": "Email, SMS, WhatsApp, Voice — how the system talks to people",
      "payments": "Stripe, Square, PayPal — how money moves",
      "documents": "E-signatures, lease/event templates, PDFs",
      "smart_home": "Lighting, cameras, music, climate, laundry, oven — IoT device control",
      "maker_tools": "3D printer, laser cutter — creative workshop equipment",
      "vehicles": "Tesla Fleet API — vehicle monitoring and commands",
      "property_ops": "Rentals, events, associates, residents, Airbnb — property management workflows",
      "ai": "AI assistant, voice calling, Alexa — intelligent automation"
    }
  },

  "personas": {
    "vacation_rental": {
      "label": "Vacation Rental Manager",
      "description": "Short-term rental with Airbnb sync, guest check-in, cleaning coordination, event hosting, and smart home controls for guests.",
      "features": ["email", "sms", "payments_stripe", "esignatures", "documents", "airbnb", "rentals", "events", "residents", "cameras", "lighting", "climate", "music"],
      "suggested_services": ["email", "payments_stripe", "esignatures"]
    },
    "long_term_landlord": {
      "label": "Long-term Landlord",
      "description": "Lease management, rent collection via ACH, maintenance coordination, and tenant communication. No smart home overhead.",
      "features": ["email", "payments_stripe", "esignatures", "documents", "rentals", "residents"],
      "suggested_services": ["email", "payments_stripe", "esignatures"]
    },
    "event_venue": {
      "label": "Event Venue",
      "description": "Event hosting pipeline with inquiry → contract → payment → execution workflow. Media galleries and guest communication.",
      "features": ["email", "sms", "payments_stripe", "payments_paypal", "esignatures", "documents", "events"],
      "suggested_services": ["email", "payments_stripe"]
    },
    "hostel_coliving": {
      "label": "Hostel / Co-living Space",
      "description": "Mixed room types, work-trade programs, orientation materials, waivers, associate hour tracking, and shared amenity controls.",
      "features": ["email", "sms", "payments_stripe", "esignatures", "documents", "rentals", "residents", "associates", "lighting", "music", "laundry"],
      "suggested_services": ["email", "payments_stripe"]
    },
    "personal_ai_hub": {
      "label": "Personal AI Hub",
      "description": "AI assistant with smart home control — lights, music, cameras, climate. Voice calling and chat interface. No property management.",
      "features": ["pai", "lighting", "music", "climate", "cameras", "voice", "residents"],
      "suggested_services": []
    },
    "small_business": {
      "label": "Small Business Platform",
      "description": "Customer communication, invoicing, payment collection, and document management. Clean CRM-style foundation.",
      "features": ["email", "sms", "payments_stripe", "documents", "esignatures"],
      "suggested_services": ["email", "payments_stripe"]
    },
    "developer_portfolio": {
      "label": "Developer Portfolio / SaaS Starter",
      "description": "Auth, payments, email notifications — minimal feature set for building a web app or portfolio site.",
      "features": ["email", "payments_stripe"],
      "suggested_services": ["email"]
    }
  },

